```gitignore
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
venv/
.env
.venv/

# Jupyter
.ipynb_checkpoints/

# macOS
.DS_Store

# VS Code
.vscode/

# Logs
*.log

# Environment variables
.env.local

# Python build files
build/
dist/
*.egg-info/

# Cache
.pytest_cache/
.mypy_cache/

# Large data files (optional)
data/raw/*.csv
data/processed/*.csv

```
